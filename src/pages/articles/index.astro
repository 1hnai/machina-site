---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Articles — Machina"
  description="AI business intelligence: tool teardowns, case studies, and operator insights from Machina."
>
  <h1 style="font-size:1.75rem; font-weight:800; letter-spacing:-0.02em; margin-bottom:0.5rem;">Articles</h1>
  <p style="color:var(--brand-muted); margin-bottom:3rem;">AI business intelligence — tools, case studies, and signal for operators.</p>

  <div style="text-align:center; padding:4rem 0; border:1px dashed var(--brand-border); border-radius:12px;">
    <p style="font-size:1.1rem; font-weight:600; margin-bottom:0.5rem;">First issue coming soon</p>
    <p style="color:var(--brand-muted); margin-bottom:1.5rem;">Subscribe to get notified when we launch.</p>
    <div class="subscribe-form" style="margin:0 auto; max-width:380px;">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Notify me</button>
    </div>
  </div>
</BaseLayout>
